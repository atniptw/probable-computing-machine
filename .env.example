# Vite base path for asset URLs and routing prefix.
# Default for local dev: / (app served from the domain root)
# Override for production: set to your deploy subpath (e.g. /probable-computing-machine/ for GitHub Pages).
VITE_BASE_PATH=/

# Canonical origin of the deployed app (no trailing slash).
# Used for <link rel="canonical">, og:url, and og:image in index.html.
# Leave blank for local dev — no canonical URL is needed.
# Override for production: set to the deployed origin (e.g. https://atniptw.github.io).
#VITE_APP_URL=

# GitHub repository in owner/repo format.
# Controls the user-guide and issue-reporting links in the app header.
# Dev-ready default points at this repo so header links render locally.
# Override for production or forks: set to your own owner/repo.
VITE_GITHUB_REPO=atniptw/probable-computing-machine
