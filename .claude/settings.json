{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx playwright test*)",
      "Bash(node /tmp/*.mjs*)",
      "Bash(gh issue view*)",
      "Bash(gh issue edit*)",
      "Bash(git add*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git status*)",
      "Bash(git commit*)",
      "Bash(curl -s http://127.0.0.1*)",
      "Bash(sleep *)",
      "Bash(rm /tmp/vqa-*)",
      "Bash(rm /tmp/visual-qa-*)",
      "Bash(rm /tmp/dr-*)",
      "Bash(rm /tmp/design-review-*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/atnip/projects/probable-computing-machine && npm run lint && npm run tsc"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/atnip/projects/probable-computing-machine && npm run test"
          }
        ]
      }
    ]
  }
}
